# Committed non-secret DEFAULTS. Symfony loads this when a local `.env` is absent
# (as in the production image, where `.env` is gitignored/dockerignored). Real
# values come from `.env.local` (mounted on the VPS) and override everything here.
# NEVER put a real secret in this file.

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=dist_placeholder_override_in_env_local
APP_SHARE_DIR=var/share

# Overridden at runtime. Placeholder must stay syntactically valid so the
# container compiles at build time (no DB connection happens during warmup).
DATABASE_URL="mysql://user:pass@db:3306/licensing?serverVersion=mariadb-11.4.0&charset=utf8mb4"

DEFAULT_URI=https://checkoutly.app

# License signing
LICENSE_PRIVATE_KEY=
LICENSE_PRIVATE_KEY_PATH=/etc/checkoutly/license-private.pem
LICENSE_PUBLIC_KEY=

# API gateway
GATEWAY_QUOTA_VAT=2000
GATEWAY_QUOTA_PLACES=1000
GOOGLE_PLACES_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# OAuth
OAUTH_GOOGLE_ID=
OAUTH_GOOGLE_SECRET=
OAUTH_FACEBOOK_ID=
OAUTH_FACEBOOK_SECRET=

###> sentry/sentry-symfony ###
SENTRY_DSN=
###< sentry/sentry-symfony ###
