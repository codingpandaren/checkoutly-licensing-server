# Copy to `.env` ON THE VPS (next to docker-compose.prod.yml). Never commit it.
# Docker Compose reads this automatically for ${...} interpolation: DB creds for
# the mariadb service + the Let's Encrypt contact email.

DB_NAME=licensing
DB_USER=checkoutly
DB_PASSWORD=CHANGE_ME
DB_ROOT_PASSWORD=CHANGE_ME_TOO

# Let's Encrypt sends cert-expiry notices here.
ACME_EMAIL=you@checkoutly.app
