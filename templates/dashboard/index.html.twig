{% extends 'base.html.twig' %}

{% block title %}Dashboard · Checkoutly Licensing{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .dash-head { display:flex; justify-content:space-between; align-items:center; gap:12px; margin:0 0 20px; flex-wrap:wrap; }

        .lic-list { display:flex; flex-direction:column; gap:12px; }
        .lic-card { display:flex; align-items:center; gap:16px; padding:16px 18px; color:inherit; transition:border-color .15s ease, box-shadow .15s ease, transform .06s ease; }
        .lic-card:hover { text-decoration:none; border-color:#c7d2e5; box-shadow:0 6px 20px rgba(16,24,40,.08); }
        .lic-card:active { transform:translateY(1px); }
        .lic-card__icon { width:46px; height:46px; border-radius:12px; background:var(--grad); color:#fff; display:flex; align-items:center; justify-content:center; flex:none; font-size:20px; font-weight:700; text-transform:uppercase; }
        .lic-card__icon--empty { background:#e2e8f0; color:var(--muted); }
        .lic-card__body { flex:1; min-width:0; }
        .lic-card__title { font-weight:700; font-size:15.5px; letter-spacing:-.01em; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
        .lic-card__title.is-empty { color:var(--muted); font-weight:600; font-style:italic; }
        .lic-card__meta { display:flex; align-items:center; gap:8px; margin-top:5px; font-size:13px; color:var(--muted); flex-wrap:wrap; }
        .lic-card__chev { flex:none; color:#c0c8d6; }

        .pricing { margin-top:32px; }
        .pricing__hero { text-align:center; max-width:560px; margin:0 auto 24px; }
        .pricing__hero h2 { font-size:26px; margin:0 0 8px; letter-spacing:-.02em; }
        .pricing__hero p { color:var(--muted); margin:0; font-size:15px; }

        .features { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; max-width:640px; margin:0 auto 32px; }
        .feature { display:flex; align-items:center; gap:9px; padding:12px 13px; background:var(--card); border:1px solid var(--line); border-radius:10px; font-size:13.5px; font-weight:500; box-shadow:var(--shadow); }
        .feature svg { flex:none; }

        .plans { display:grid; grid-template-columns:repeat(2,1fr); gap:18px; align-items:stretch; max-width:720px; margin:0 auto; }
        .plan { position:relative; display:flex; flex-direction:column; padding:26px 24px; }
        .plan--best { border-color:transparent; box-shadow:0 0 0 2px #10b981, 0 12px 32px rgba(16,185,129,.14); }
        .plan__badge { position:absolute; top:16px; right:16px; background:var(--grad); color:#fff; font-size:11px; font-weight:700; letter-spacing:.02em; text-transform:uppercase; padding:4px 10px; border-radius:999px; }
        .plan__name { font-weight:700; font-size:14px; text-transform:uppercase; letter-spacing:.04em; color:var(--muted); }
        .plan__price { display:flex; align-items:baseline; gap:6px; margin:12px 0 2px; }
        .plan__amt { font-size:38px; font-weight:800; letter-spacing:-.03em; }
        .plan__per { color:var(--muted); font-size:14px; }
        .plan__sub { color:var(--muted); font-size:13px; min-height:20px; margin-bottom:18px; }
        .plan__save { color:var(--ok); font-weight:600; }
        .plan__feats { list-style:none; margin:0 0 20px; padding:18px 0 0; border-top:1px solid var(--line); display:flex; flex-direction:column; gap:9px; font-size:13.5px; }
        .plan__feats li { display:flex; align-items:flex-start; gap:9px; }
        .plan__feats svg { flex:none; margin-top:2px; }
        .plan form { margin-top:auto; }

        .reassure { display:flex; justify-content:center; gap:22px; flex-wrap:wrap; margin-top:22px; color:var(--muted); font-size:13px; }
        .reassure span { display:inline-flex; align-items:center; gap:6px; }

        @media (max-width:640px) {
            .features { grid-template-columns:repeat(2,1fr); }
            .plans { grid-template-columns:1fr; }
        }
    </style>
{% endblock %}

{% block body %}
    {% set checkout = app.request.query.get('checkout') %}
    {% if checkout == 'success' %}
        <div class="flash flash--success">Payment received - your license will appear here as soon as Stripe confirms it (usually a few seconds).</div>
    {% elseif checkout == 'cancel' %}
        <div class="flash flash--error">Checkout canceled - you have not been charged.</div>
    {% endif %}

    <div class="dash-head">
        <div>
            <h1 style="font-size:22px; margin:0 0 4px;">Your licenses</h1>
            <p class="muted" style="margin:0;">Signed in as {{ app.user.email }}.</p>
        </div>
        {% if app.user.stripeCustomerId %}
            <form method="post" action="{{ path('app_billing_portal') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('billing_portal') }}">
                <button type="submit" class="btn">Manage billing</button>
            </form>
        {% endif %}
    </div>

    {% if licenses is not empty %}
        <div class="lic-list">
            {% for license in licenses %}
                <a href="{{ path('app_license_show', {id: license.id}) }}" class="card lic-card">
                    {% if license.registeredDomain %}
                        <div class="lic-card__icon">{{ license.registeredDomain|first }}</div>
                    {% else %}
                        <div class="lic-card__icon lic-card__icon--empty">?</div>
                    {% endif %}
                    <div class="lic-card__body">
                        {% if license.registeredDomain %}
                            <div class="lic-card__title">{{ license.registeredDomain }}</div>
                        {% else %}
                            <div class="lic-card__title is-empty">No domain registered yet</div>
                        {% endif %}
                        <div class="lic-card__meta">
                            <span>Checkoutly {{ license.tier|capitalize }}</span>
                            <span>·</span>
                            {% if license.revoked %}
                                <span class="pill pill--bad">revoked</span>
                            {% elseif license.status in ['active', 'trialing'] %}
                                <span class="pill pill--ok">{{ license.status }}</span>
                            {% elseif license.status == 'past_due' %}
                                <span class="pill pill--warn">past due</span>
                            {% else %}
                                <span class="pill pill--mute">{{ license.status }}</span>
                            {% endif %}
                            {% if not license.registeredDomain %}
                                <span class="pill pill--warn">action needed</span>
                            {% endif %}
                        </div>
                    </div>
                    <svg class="lic-card__chev" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            {% endfor %}
        </div>
    {% endif %}

    <section class="pricing">
        <div class="pricing__hero">
            <h2>{{ licenses is empty ? 'Turn abandoned carts into orders' : 'Add another license' }}</h2>
            <p>Checkoutly Pro unlocks the anti-abandonment tools that keep shoppers from leaving before they pay - one license per store.</p>
        </div>

        {% if licenses is empty %}
            {% set feats = [
                'Smart conditional fields',
                'Address autocomplete',
                'Real-time validation',
                'Exit-intent cart save',
                'Abandoned-cart emails',
                'And more',
            ] %}
            <div class="features">
                {% for f in feats %}
                    <div class="feature">
                        <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="12" fill="#10b981" opacity=".12"/><path d="M7 12.5l3.2 3.2L17 9" fill="none" stroke="#10b981" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        {{ f }}
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {% set included = ['All Pro anti-abandonment features', 'One store domain, transferable anytime', 'Free updates & priority support'] %}
        <div class="plans">
            <div class="card plan">
                <div class="plan__name">Monthly</div>
                <div class="plan__price">
                    <span class="plan__amt">{{ pricing.currency }}{{ pricing.monthly }}</span>
                    <span class="plan__per">/ month</span>
                </div>
                <div class="plan__sub">Billed monthly. Cancel anytime.</div>
                <ul class="plan__feats">
                    {% for item in included %}
                        <li><svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12.5l4 4L19 7" fill="none" stroke="#94a3b8" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>{{ item }}</li>
                    {% endfor %}
                </ul>
                <form method="post" action="{{ path('app_billing_subscribe') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                    <input type="hidden" name="plan" value="monthly">
                    <button type="submit" class="btn btn--block">Subscribe monthly</button>
                </form>
            </div>

            <div class="card plan plan--best">
                <div class="plan__badge">Best value</div>
                <div class="plan__name">Yearly</div>
                <div class="plan__price">
                    <span class="plan__amt">{{ pricing.currency }}{{ pricing.yearly }}</span>
                    <span class="plan__per">/ year</span>
                </div>
                <div class="plan__sub">Just {{ pricing.currency }}{{ pricing.yearly_per_month }}/mo - <span class="plan__save">save {{ pricing.currency }}{{ pricing.yearly_saving }}, 2 months free</span>.</div>
                <ul class="plan__feats">
                    {% for item in included %}
                        <li><svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12.5l4 4L19 7" fill="none" stroke="#10b981" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>{{ item }}</li>
                    {% endfor %}
                </ul>
                <form method="post" action="{{ path('app_billing_subscribe') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                    <input type="hidden" name="plan" value="yearly">
                    <button type="submit" class="btn btn--primary btn--block">Subscribe yearly</button>
                </form>
            </div>
        </div>

        <div class="reassure">
            <span>🔒 Secure payment by Stripe</span>
            <span>⚡ Instant license delivery</span>
            <span>↩ Cancel anytime</span>
        </div>
    </section>
{% endblock %}
