{% extends 'base.html.twig' %}

{% block title %}Dashboard · Checkoutly Licensing{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .dash-head { display:flex; justify-content:space-between; align-items:center; gap:12px; margin:0 0 20px; flex-wrap:wrap; }
        .dash-head__actions { display:flex; gap:10px; flex-wrap:wrap; }

        .empty { text-align:center; padding:40px 24px; border:1px dashed #d6dde8; border-radius:16px; background:var(--card); }
        .empty__icon { width:52px; height:52px; border-radius:14px; background:#f1f5f9; color:#94a3b8; display:flex; align-items:center; justify-content:center; margin:0 auto 14px; }
        .empty__title { font-weight:700; font-size:16px; margin:0 0 4px; }
        .empty p.muted { max-width:400px; margin:0 auto; }

        .lic-list { display:flex; flex-direction:column; gap:12px; }
        .lic-card { display:flex; align-items:center; gap:16px; padding:16px 18px; color:inherit; transition:border-color .15s ease, box-shadow .15s ease, transform .06s ease; }
        .lic-card:hover { text-decoration:none; border-color:#c7d2e5; box-shadow:0 6px 20px rgba(16,24,40,.08); }
        .lic-card:active { transform:translateY(1px); }
        .lic-card__icon { width:46px; height:46px; border-radius:12px; background:var(--accent); color:#fff; display:flex; align-items:center; justify-content:center; flex:none; font-size:20px; font-weight:700; text-transform:uppercase; }
        .lic-card__icon--empty { background:#e2e8f0; color:var(--muted); }
        .lic-card__body { flex:1; min-width:0; }
        .lic-card__title { font-weight:700; font-size:15.5px; letter-spacing:-.01em; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
        .lic-card__title.is-empty { color:var(--muted); font-weight:600; font-style:italic; }
        .lic-card__meta { display:flex; align-items:center; gap:8px; margin-top:5px; font-size:13px; color:var(--muted); flex-wrap:wrap; }
        .lic-card__chev { flex:none; color:#c0c8d6; }
    </style>
{% endblock %}

{% block body %}
    {% set checkout = app.request.query.get('checkout') %}
    {% if checkout == 'success' %}
        <div class="flash flash--success">All set - your license will appear here as soon as your payment is confirmed (usually a few seconds).</div>
    {% elseif checkout == 'cancel' %}
        <div class="flash flash--error">Checkout canceled - you have not been charged.</div>
    {% endif %}

    <div class="dash-head">
        <h1 style="font-size:22px; margin:0;">Your licenses</h1>
        {% if licenses is not empty %}
            <div class="dash-head__actions">
                <a href="{{ path('app_pricing') }}" class="btn btn--primary">Buy another license</a>
                {% if app.user.stripeCustomerId %}
                    <form method="post" action="{{ path('app_billing_portal') }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('billing_portal') }}">
                        <button type="submit" class="btn">Manage billing</button>
                    </form>
                {% endif %}
            </div>
        {% endif %}
    </div>

    {% if licenses is empty %}
        <div class="empty">
            <div class="empty__icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M0 8a4 4 0 0 1 7.465-2H14a.5.5 0 0 1 .354.146l1.5 1.5a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0L13 9.207l-.646.647a.5.5 0 0 1-.708 0L11 9.207l-.646.647a.5.5 0 0 1-.708 0L9 9.207l-.646.647A.5.5 0 0 1 8 10h-.535A4 4 0 0 1 0 8m4-3a3 3 0 1 0 2.712 4.285A.5.5 0 0 1 7.163 9h.63l.853-.854a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.793-.793-1-1h-6.63a.5.5 0 0 1-.451-.285A3 3 0 0 0 4 5"/><path d="M4 8a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/></svg>
            </div>
            <p class="empty__title">No licenses yet</p>
            <p class="muted">Unlock Checkoutly Pro to turn abandoned carts into completed orders. Choose a plan to get started.</p>
            <a href="{{ path('app_pricing') }}" class="btn btn--primary" style="margin-top:18px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M0 8a4 4 0 0 1 7.465-2H14a.5.5 0 0 1 .354.146l1.5 1.5a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0L13 9.207l-.646.647a.5.5 0 0 1-.708 0L11 9.207l-.646.647a.5.5 0 0 1-.708 0L9 9.207l-.646.647A.5.5 0 0 1 8 10h-.535A4 4 0 0 1 0 8m4-3a3 3 0 1 0 2.712 4.285A.5.5 0 0 1 7.163 9h.63l.853-.854a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.793-.793-1-1h-6.63a.5.5 0 0 1-.451-.285A3 3 0 0 0 4 5"/><path d="M4 8a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/></svg>
                Choose a plan
            </a>
        </div>
    {% else %}
        <div class="lic-list">
            {% for license in licenses %}
                <a href="{{ path('app_license_show', {id: license.id}) }}" class="card lic-card">
                    {% if license.registeredDomain %}
                        <div class="lic-card__icon">{{ license.registeredDomain|first }}</div>
                    {% else %}
                        <div class="lic-card__icon lic-card__icon--empty">?</div>
                    {% endif %}
                    <div class="lic-card__body">
                        {% if license.registeredDomain %}
                            <div class="lic-card__title">{{ license.registeredDomain }}</div>
                        {% else %}
                            <div class="lic-card__title is-empty">No domain registered yet</div>
                        {% endif %}
                        <div class="lic-card__meta">
                            <span>Checkoutly {{ license.tier|capitalize }}</span>
                            <span>·</span>
                            {% if license.revoked %}
                                <span class="pill pill--bad">Revoked</span>
                            {% elseif license.status in ['active', 'trialing', 'past_due'] and license.endsAt %}
                                <span class="pill pill--warn">Cancels {{ license.endsAt|date('Y-m-d') }}</span>
                            {% elseif license.status == 'trialing' %}
                                <span class="pill pill--ok">Trial</span>
                            {% elseif license.status == 'active' %}
                                <span class="pill pill--ok">Active</span>
                            {% elseif license.status == 'past_due' %}
                                <span class="pill pill--warn">Past due</span>
                            {% else %}
                                <span class="pill pill--mute">{{ license.status|replace({'_': ' '})|capitalize }}</span>
                            {% endif %}
                            {% if not license.registeredDomain %}
                                <span class="pill pill--warn">Domain not registered</span>
                            {% endif %}
                        </div>
                    </div>
                    <svg class="lic-card__chev" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
