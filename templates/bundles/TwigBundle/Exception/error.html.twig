{# Customer-facing error page. Deliberately self-contained — no base layout,
   no app.user (which would hit the DB), no assets — so it renders even when the
   thing that failed is the database or the session. Covers every status code;
   Symfony passes status_code / status_text. #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ status_code }} · Checkoutly</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: #f4f6fb; color: #151b26; -webkit-font-smoothing: antialiased; padding: 24px;
        }
        .box { max-width: 460px; width: 100%; text-align: center; }
        .brand { font-weight: 700; font-size: 18px; letter-spacing: -.01em; margin-bottom: 44px; }
        .brand span { color: #059669; }
        .code { font-size: 68px; font-weight: 800; letter-spacing: -.03em; color: #059669; line-height: 1; }
        h1 { font-size: 22px; font-weight: 700; letter-spacing: -.01em; margin: 16px 0 10px; }
        p { font-size: 15px; line-height: 1.6; color: #6b7787; margin: 0 auto 28px; max-width: 380px; }
        .btn {
            display: inline-flex; align-items: center; justify-content: center; padding: 11px 22px;
            border-radius: 10px; background: #059669; color: #fff; font-size: 14px; font-weight: 600;
            text-decoration: none; transition: background .15s ease;
        }
        .btn:hover { background: #047857; }
    </style>
</head>
<body>
    <div class="box">
        <div class="brand">Checkout<span>ly</span></div>
        <div class="code">{{ status_code }}</div>
        {% if status_code == 404 %}
            <h1>Page not found</h1>
            <p>The page you’re looking for doesn’t exist or may have moved.</p>
        {% elseif status_code == 403 %}
            <h1>Access denied</h1>
            <p>You don’t have permission to view this page. Try signing in with the right account.</p>
        {% elseif status_code >= 500 %}
            <h1>Something went wrong</h1>
            <p>An unexpected error occurred on our end. We’ve been notified and are looking into it — please try again in a moment.</p>
        {% else %}
            <h1>{{ status_text|default('Something went wrong') }}</h1>
            <p>We couldn’t complete your request. Please try again.</p>
        {% endif %}
        <a class="btn" href="/">Back to Checkoutly</a>
    </div>
</body>
</html>
