{% extends 'base.html.twig' %}

{% block title %}Choose a plan · Checkoutly Licensing{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .pricing__hero { text-align:center; max-width:560px; margin:0 auto 28px; }
        .pricing__hero h1 { font-size:28px; margin:0 0 8px; letter-spacing:-.02em; }
        .pricing__hero p { color:var(--muted); margin:0; font-size:15px; }

        .features { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; max-width:640px; margin:0 auto 32px; }
        .feature { display:flex; align-items:center; gap:9px; padding:12px 13px; background:var(--card); border:1px solid var(--line); border-radius:10px; font-size:13.5px; font-weight:500; box-shadow:var(--shadow); }
        .feature svg { flex:none; }

        .plans { display:grid; grid-template-columns:repeat(2,1fr); gap:18px; align-items:stretch; max-width:720px; margin:0 auto; }
        .plans--3 { grid-template-columns:repeat(3,1fr); max-width:940px; }
        .plan { position:relative; display:flex; flex-direction:column; padding:26px 24px; }
        .plan--best { border-color:transparent; box-shadow:0 0 0 2px #059669, 0 12px 32px rgba(5,150,105,.14); }
        .plan__head { display:flex; align-items:center; justify-content:space-between; gap:8px; min-height:24px; }
        .plan__badge { background:var(--accent); color:#fff; font-size:11px; font-weight:700; letter-spacing:.02em; text-transform:uppercase; padding:4px 10px; border-radius:999px; }
        .plan__badge--soft { background:#eef2f7; color:var(--muted); }
        .plan__name { font-weight:700; font-size:14px; text-transform:uppercase; letter-spacing:.04em; color:var(--muted); }
        .plan__price { display:flex; align-items:baseline; gap:6px; margin:12px 0 2px; }
        .plan__amt { font-size:38px; font-weight:800; letter-spacing:-.03em; }
        .plan__per { color:var(--muted); font-size:14px; }
        .plan__sub { color:var(--muted); font-size:13px; min-height:20px; margin-bottom:14px; }
        .plan__scope { display:flex; align-items:center; gap:7px; font-size:12.5px; color:#047857; background:#ecfdf5; border:1px solid #d1fae5; border-radius:8px; padding:7px 10px; margin-bottom:16px; }
        .plan__scope svg { flex:none; }
        .plan__save { color:var(--ok); font-weight:600; }
        .plan__feats { list-style:none; margin:0 0 20px; padding:18px 0 0; border-top:1px solid var(--line); display:flex; flex-direction:column; gap:9px; font-size:13.5px; }
        .plan__feats li { display:flex; align-items:flex-start; gap:9px; }
        .plan__feats svg { flex:none; margin-top:2px; }
        .plan form { margin-top:auto; }

        .reassure { display:flex; justify-content:center; gap:22px; flex-wrap:wrap; margin-top:22px; color:var(--muted); font-size:13px; }
        .reassure span { display:inline-flex; align-items:center; gap:6px; }

        @media (max-width:820px) {
            .plans--3 { grid-template-columns:1fr; max-width:420px; }
        }
        @media (max-width:640px) {
            .features { grid-template-columns:repeat(2,1fr); }
            .plans { grid-template-columns:1fr; max-width:420px; }
        }
    </style>
{% endblock %}

{% block body %}
    <p style="margin:0 0 20px;"><a href="{{ path('app_dashboard') }}">← Back to your licenses</a></p>

    <div class="pricing__hero">
        <h1>Turn abandoned carts into orders</h1>
        <p>Checkoutly Pro unlocks the anti-abandonment tools that keep shoppers from leaving before they pay - one license per store.</p>
        {% if trialEligible %}
            <p style="margin-top:10px; font-weight:600; color:var(--accent);">Start with a {{ trialDays }}-day free trial. Cancel anytime before it ends and you won't be charged.</p>
        {% endif %}
    </div>

    {% set feats = [
        'Smart conditional fields',
        'Address autocomplete',
        'Real-time validation',
        'Exit-intent cart save',
        'Abandoned-cart emails',
        'And more',
    ] %}
    <div class="features">
        {% for f in feats %}
            <div class="feature">
                <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="12" fill="#059669" opacity=".12"/><path d="M7 12.5l3.2 3.2L17 9" fill="none" stroke="#059669" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                {{ f }}
            </div>
        {% endfor %}
    </div>

    {% set included = ['All Pro anti-abandonment features', 'Transfer to a new domain anytime', 'Free updates & priority support'] %}
    {% macro feats(list, color) %}
        <ul class="plan__feats">
            {% for item in list %}
                <li><svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12.5l4 4L19 7" fill="none" stroke="{{ color }}" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>{{ item }}</li>
            {% endfor %}
        </ul>
    {% endmacro %}
    {% macro scope() %}
        <div class="plan__scope">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true"><path d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m7.5-6.923c-.67.204-1.335.82-1.887 1.855A8 8 0 0 0 5.145 4H7.5zM4.09 4a9.3 9.3 0 0 1 .64-1.539 7 7 0 0 1 .597-.933A7.03 7.03 0 0 0 2.255 4zm-.582 3.5c.03-.877.138-1.718.312-2.5H1.674a7 7 0 0 0-.656 2.5zM4.847 5a12.5 12.5 0 0 0-.338 2.5H7.5V5zM8.5 5v2.5h2.99a12.5 12.5 0 0 0-.337-2.5zM4.51 8.5a12.5 12.5 0 0 0 .337 2.5H7.5V8.5zm3.99 0V11h2.653c.187-.765.306-1.608.338-2.5zM5.145 12q.208.58.468 1.068c.552 1.035 1.218 1.65 1.887 1.855V12zm.182 2.472a7 7 0 0 1-.597-.933A9.3 9.3 0 0 1 4.09 12H2.255a7 7 0 0 0 3.072 2.472M3.82 11a13.7 13.7 0 0 1-.312-2.5h-2.49c.062.89.291 1.733.656 2.5zm6.853 3.472A7 7 0 0 0 13.745 12H11.91a9.3 9.3 0 0 1-.64 1.539 7 7 0 0 1-.597.933M8.5 12v2.923c.67-.204 1.335-.82 1.887-1.855q.26-.487.468-1.068zm3.68-1h2.146c.365-.767.594-1.61.656-2.5h-2.49a13.7 13.7 0 0 1-.312 2.5m2.802-3.5a7 7 0 0 0-.656-2.5H12.18c.174.782.282 1.623.312 2.5zM11.27 2.461c.247.464.462.98.64 1.539h1.835a7 7 0 0 0-3.072-2.472c.218.284.418.598.597.933M10.855 4a8 8 0 0 0-.468-1.068C9.835 1.897 9.17 1.282 8.5 1.077V4z"/></svg>
            Works on <strong>1 store domain</strong>
        </div>
    {% endmacro %}
    {% import _self as ui %}

    <div class="plans {{ trialEligible ? 'plans--3' }}">
        {% if trialEligible %}
            <div class="card plan">
                <div class="plan__head">
                    <div class="plan__name">Free trial</div>
                    <div class="plan__badge plan__badge--soft">{{ trialDays }} days free</div>
                </div>
                <div class="plan__price">
                    <span class="plan__amt">{{ pricing.currency }}0</span>
                    <span class="plan__per">for {{ trialDays }} days</span>
                </div>
                <div class="plan__sub">Free until {{ 'now'|date_modify('+' ~ trialDays ~ ' days')|date('M j') }}, then {{ pricing.currency }}{{ pricing.monthly }}/mo. Cancel anytime before then and you won't be charged.</div>
                {{ ui.scope() }}
                {{ ui.feats(included, '#94a3b8') }}
                <form method="post" action="{{ path('app_billing_subscribe') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                    <input type="hidden" name="plan" value="monthly">
                    <input type="hidden" name="trial" value="1">
                    <button type="submit" class="btn btn--block">Start free trial</button>
                </form>
            </div>
        {% endif %}

        <div class="card plan">
            <div class="plan__head">
                <div class="plan__name">Monthly</div>
            </div>
            <div class="plan__price">
                <span class="plan__amt">{{ pricing.currency }}{{ pricing.monthly }}</span>
                <span class="plan__per">/ month</span>
            </div>
            <div class="plan__sub">Billed monthly, starting today. Cancel anytime.</div>
            {{ ui.scope() }}
            {{ ui.feats(included, '#94a3b8') }}
            <form method="post" action="{{ path('app_billing_subscribe') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                <input type="hidden" name="plan" value="monthly">
                <button type="submit" class="btn btn--block">Subscribe monthly</button>
            </form>
        </div>

        <div class="card plan plan--best">
            <div class="plan__head">
                <div class="plan__name">Yearly</div>
                <div class="plan__badge">Best value</div>
            </div>
            <div class="plan__price">
                <span class="plan__amt">{{ pricing.currency }}{{ pricing.yearly }}</span>
                <span class="plan__per">/ year</span>
            </div>
            <div class="plan__sub">{{ pricing.currency }}{{ pricing.yearly_per_month }}/mo billed yearly.<br><span class="plan__save">Save {{ pricing.currency }}{{ pricing.yearly_saving }}, 2 months free.</span></div>
            {{ ui.scope() }}
            {{ ui.feats(included, '#059669') }}
            <form method="post" action="{{ path('app_billing_subscribe') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('billing_subscribe') }}">
                <input type="hidden" name="plan" value="yearly">
                <button type="submit" class="btn btn--primary btn--block">Subscribe yearly</button>
            </form>
        </div>
    </div>

    <div class="reassure">
        {% if trialEligible %}<span>🎁 {{ trialDays }}-day free trial</span>{% endif %}
        <span>🔒 Secure payment by Stripe</span>
        <span>⚡ Instant license delivery</span>
        <span>↩ Cancel anytime</span>
    </div>
{% endblock %}
