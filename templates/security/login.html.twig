{% extends 'base.html.twig' %}

{% block title %}Sign in · Checkoutly{% endblock %}

{% block topbar_actions %}
    <style>
        .demo-cta { display:inline-flex; align-items:stretch; border-radius:10px; overflow:hidden; box-shadow:0 4px 12px rgba(15,118,88,.22); }
        .demo-cta__part { display:inline-flex; align-items:center; gap:7px; padding:9px 14px; background:var(--accent); color:var(--accent-ink); font-size:13.5px; font-weight:600; line-height:1.2; text-decoration:none; white-space:nowrap; transition:background .15s ease; }
        .demo-cta__part:hover { background:var(--accent-dark); text-decoration:none; }
        .demo-cta__part:focus-visible { outline:2px solid var(--accent-ink); outline-offset:-4px; }
        .demo-cta__part + .demo-cta__part { border-left:1px solid rgba(255,255,255,.3); }
        .demo-cta svg { flex:none; }
        .demo-cta__ext { opacity:.85; margin-left:1px; }
        @media (max-width:560px) {
            .demo-cta__part { padding:8px 11px; font-size:12.5px; gap:6px; }
        }
        @media (max-width:380px) {
            .demo-cta__part { padding:8px 10px; }
            .demo-cta__label { position:absolute; width:1px; height:1px; padding:0; overflow:hidden; clip:rect(0 0 0 0); white-space:nowrap; border:0; }
        }
    </style>
    <div class="demo-cta" role="group" aria-label="See the Checkoutly demo">
        <a class="demo-cta__part" href="https://demo.checkoutly.app" target="_blank" rel="noopener" title="Open the storefront checkout demo">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="demo-cta__label">Storefront demo</span>
            <svg class="demo-cta__ext" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
        <a class="demo-cta__part" href="https://demo.checkoutly.app/admin-demo" target="_blank" rel="noopener" title="Open the back-office demo">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
            <span class="demo-cta__label">BO demo</span>
            <svg class="demo-cta__ext" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
    </div>
{% endblock %}

{% block body %}
    <div class="card" style="max-width:420px; margin:56px auto; text-align:center;">
        <img src="{{ asset('logo-full.png') }}" alt="Checkoutly" width="200" style="height:auto; max-width:70%; margin:0 auto 18px; display:block;">
        <h1 style="font-size:22px; margin:0 0 6px; letter-spacing:-.01em;">Sign in to your dashboard</h1>
        <p class="muted" style="margin:0 0 24px;">View your license key, register your store domains and manage your subscription - all in one place.</p>

        <a class="btn btn--block" href="{{ path('connect_google') }}" style="margin-bottom:12px;">
            <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>
            Continue with Google
        </a>

        <a class="btn btn--block" href="{{ path('connect_facebook') }}" style="margin-bottom:12px;">
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true"><path fill="#1877F2" d="M24 12c0-6.63-5.37-12-12-12S0 5.37 0 12c0 5.99 4.39 10.95 10.13 11.85v-8.38H7.08V12h3.05V9.36c0-3.01 1.79-4.67 4.53-4.67 1.31 0 2.68.23 2.68.23v2.95h-1.51c-1.49 0-1.95.93-1.95 1.87V12h3.32l-.53 3.47h-2.79v8.38C19.61 22.95 24 17.99 24 12z"/></svg>
            Continue with Facebook
        </a>

        <a class="btn btn--block" href="{{ path('connect_apple') }}" style="background:#000; border-color:#000; color:#fff;">
            <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true"><path fill="#fff" d="M17.05 12.54c-.03-2.6 2.13-3.85 2.22-3.91-1.21-1.77-3.1-2.01-3.77-2.04-1.6-.16-3.13.94-3.94.94-.82 0-2.07-.92-3.4-.9-1.75.03-3.36 1.02-4.26 2.58-1.82 3.16-.46 7.83 1.3 10.39.86 1.26 1.88 2.66 3.22 2.61 1.29-.05 1.78-.83 3.34-.83 1.55 0 2 .83 3.37.81 1.39-.03 2.28-1.28 3.13-2.54.99-1.45 1.39-2.86 1.42-2.93-.03-.02-2.72-1.05-2.75-4.15zM14.6 4.7c.71-.86 1.19-2.06 1.06-3.25-1.02.04-2.26.68-3 1.54-.66.76-1.24 1.98-1.08 3.15 1.14.09 2.3-.58 3.02-1.44z"/></svg>
            Continue with Apple
        </a>

        <p class="muted" style="font-size:12px; margin:22px 0 0;">We only use your email to identify your account.</p>
    </div>
{% endblock %}
