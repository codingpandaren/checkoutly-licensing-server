{% extends 'base.html.twig' %}

{% block title %}License · Checkoutly Licensing{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .hint { display:flex; align-items:flex-start; gap:10px; background:#fffbeb; border:1px solid #fde68a; color:#92400e; border-radius:10px; padding:12px 14px; margin:0 0 14px; font-size:13.5px; line-height:1.5; }
        .hint svg { flex:none; margin-top:1px; }
        .hint form { display:inline; }
        .hint button { background:none; border:none; padding:0; margin:0; font:inherit; color:#92400e; font-weight:700; text-decoration:underline; cursor:pointer; }
        .hint code { font-family:ui-monospace,SFMono-Regular,Menlo,monospace; background:rgba(146,64,14,.1); padding:1px 5px; border-radius:4px; }
        .tip { position:relative; display:inline-flex; align-items:center; margin-left:5px; color:#9aa5b4; cursor:help; vertical-align:middle; }
        .tip:hover, .tip:focus { color:var(--accent); outline:none; }
        .tip__bubble { position:absolute; top:calc(100% + 9px); left:50%; transform:translateX(-50%); width:250px; background:#1c2430; color:#fff; font-size:12.5px; font-weight:400; line-height:1.5; padding:10px 12px; border-radius:8px; box-shadow:0 8px 24px rgba(16,24,40,.22); opacity:0; visibility:hidden; transition:opacity .12s ease; z-index:10; }
        .tip__bubble code { background:rgba(255,255,255,.16); padding:1px 5px; border-radius:4px; font-family:ui-monospace,SFMono-Regular,Menlo,monospace; }
        .tip__bubble::before { content:""; position:absolute; bottom:100%; left:50%; transform:translateX(-50%); border:6px solid transparent; border-bottom-color:#1c2430; }
        .tip:hover .tip__bubble, .tip:focus-within .tip__bubble { opacity:1; visibility:visible; }
    </style>
{% endblock %}

{% block body %}
    <p style="margin:0 0 16px;"><a href="{{ path('app_dashboard') }}">← Back to licenses</a></p>

    {% set entitled = not license.revoked and license.status in ['active', 'trialing', 'past_due'] %}
    <div class="card" style="margin-bottom:16px;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:12px;">
            <h1 style="font-size:20px; margin:0;">Checkoutly {{ license.tier|capitalize }}</h1>
            {% if license.revoked %}
                <span class="pill pill--bad">Revoked</span>
            {% elseif entitled and license.endsAt %}
                <span class="pill pill--warn">Canceling</span>
            {% elseif license.status == 'trialing' %}
                <span class="pill pill--ok">Trial</span>
            {% elseif entitled %}
                <span class="pill pill--ok">Active</span>
            {% else %}
                <span class="pill pill--mute">{{ license.status|replace({'_': ' '})|capitalize }}</span>
            {% endif %}
        </div>
        <dl style="display:grid; grid-template-columns:max-content 1fr; gap:8px 20px; margin:18px 0 0; font-size:14px;">
            <dt class="muted">Subscription</dt>
            <dd style="margin:0;">
                {% if license.revoked %}
                    Revoked. Premium features are disabled.
                {% elseif entitled and license.endsAt %}
                    Cancels on {{ license.endsAt|date('Y-m-d') }}. You keep premium until then.
                {% elseif license.status == 'trialing' %}
                    Free trial{% if license.currentPeriodEnd %} until {{ license.currentPeriodEnd|date('Y-m-d') }}{% endif %}. Converts to a paid {{ license.tier }} subscription automatically unless you cancel.
                {% elseif entitled %}
                    Active.{% if license.currentPeriodEnd %} Renews on {{ license.currentPeriodEnd|date('Y-m-d') }}.{% else %} Renews automatically with your {{ license.tier }} subscription.{% endif %}
                {% elseif license.status == 'canceled' %}
                    Canceled{% if license.endsAt %} on {{ license.endsAt|date('Y-m-d') }}{% endif %}. Premium features are disabled.
                {% else %}
                    {{ license.status|replace({'_': ' '})|capitalize }}
                {% endif %}
            </dd>
            <dt class="muted">Last check-in</dt>
            <dd style="margin:0;">
                {% if license.lastSeenAt %}{{ license.lastSeenAt|date('Y-m-d H:i') }}{% if license.lastSeenDomain %} from {{ license.lastSeenDomain }}{% endif %}{% else %}never{% endif %}
            </dd>
        </dl>
        {% if app.user.stripeCustomerId %}
            <p class="muted" style="margin:14px 0 0; font-size:13px;">Manage renewal, payment method or cancellation from <a href="{{ path('app_dashboard') }}">your dashboard → Manage billing</a>.</p>
        {% endif %}
    </div>

    <div class="card" style="margin-bottom:16px;">
        <h2 style="font-size:15px; margin:0 0 6px;">Your license key</h2>
        <p class="muted" style="margin:0 0 12px; font-size:13px;">Paste this into Checkoutly → License tab in your PrestaShop back office.</p>
        <div style="display:flex; gap:8px;">
            <input id="ck-key" class="btn" style="flex:1; font-family:monospace; font-size:12px; overflow:hidden; text-overflow:ellipsis; cursor:text;" value="{{ license.licenseKey }}" readonly onclick="this.select()">
            <button type="button" class="btn btn--primary" onclick="navigator.clipboard.writeText(document.getElementById('ck-key').value); this.textContent='Copied';">Copy</button>
        </div>
    </div>

    <div class="card">
        <h2 style="font-size:15px; margin:0 0 6px;">Store domain<span class="tip" tabindex="0" role="note" aria-label="Developing locally? Local stores such as localhost, *.test and *.local always work; you only need to register your live domain.">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/><path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286m1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94"/></svg>
            <span class="tip__bubble">Developing locally? Local stores (<code>localhost</code>, <code>*.test</code>, <code>*.local</code>) always work - you only need to register your live domain.</span>
        </span></h2>
        <p class="muted" style="margin:0 0 14px; font-size:13px;">
            Your license works on a single store domain. Register it here before activating the module - the key will only unlock premium features on this domain.
            {% if license.registeredDomain %}To move to a new domain (e.g. after a migration), just update it below.{% endif %}
        </p>

        {% if license.lastSeenDomain and license.lastSeenDomain != license.registeredDomain %}
            <div class="hint">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 8v5m0 3h.01M10.3 3.86l-8.06 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.76-3.14l-8.06-14a2 2 0 0 0-3.4 0z" stroke="#b45309" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <div>
                    {% if license.registeredDomain %}
                        Your shop is checking in as <code>{{ license.lastSeenDomain }}</code>, but this license is registered to <code>{{ license.registeredDomain }}</code>. Premium won't unlock until they match.
                    {% else %}
                        Your shop is checking in as <code>{{ license.lastSeenDomain }}</code> but no domain is registered yet. Register it to unlock premium.
                    {% endif %}
                    <form method="post" action="{{ path('app_license_domain', {id: license.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('license_domain_' ~ license.id) }}">
                        <input type="hidden" name="domain" value="{{ license.lastSeenDomain }}">
                        <button type="submit">Use {{ license.lastSeenDomain }}</button>
                    </form>
                </div>
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_license_domain', {id: license.id}) }}" style="display:flex; gap:8px;">
            <input type="hidden" name="_token" value="{{ csrf_token('license_domain_' ~ license.id) }}">
            <input type="text" name="domain" class="btn" style="flex:1; cursor:text;" placeholder="yourstore.com" value="{{ license.registeredDomain }}" autocomplete="off" spellcheck="false">
            <button type="submit" class="btn btn--primary">{{ license.registeredDomain ? 'Update' : 'Register' }}</button>
        </form>
    </div>
{% endblock %}
