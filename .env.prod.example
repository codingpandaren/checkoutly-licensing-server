# Copy to `.env.local` ON THE VPS and fill with REAL values. Never commit .env.local.
# These are the app's runtime secrets (Symfony reads this file in prod).

APP_ENV=prod
APP_DEBUG=0
# Generate: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=CHANGE_ME_32_HEX

# Points at the `db` service. User/password must match the DB_* in `.env`.
DATABASE_URL="mysql://checkoutly:CHANGE_ME@db:3306/licensing?serverVersion=mariadb-11.4.0&charset=utf8mb4"

# CLI URL generation (emails, absolute links).
DEFAULT_URI=https://checkoutly.app

# --- License signing ---
# Copy the private key to ./secrets/license-private.pem on the VPS (mounted here).
LICENSE_PRIVATE_KEY_PATH=/etc/checkoutly/license-private.pem
LICENSE_PUBLIC_KEY=

# --- API gateway ---
GATEWAY_QUOTA_VAT=2000
GATEWAY_QUOTA_PLACES=1000
GATEWAY_QUOTA_EMAIL=5000
GOOGLE_PLACES_API_KEY=CHANGE_ME

# --- Stripe (LIVE keys in production) ---
STRIPE_SECRET_KEY=CHANGE_ME
STRIPE_WEBHOOK_SECRET=CHANGE_ME
STRIPE_PRICE_PRO_MONTHLY=CHANGE_ME
STRIPE_PRICE_PRO_YEARLY=CHANGE_ME

# --- OAuth (redirect URIs use the portal host, e.g. https://dashboard.checkoutly.app/connect/*/check) ---
OAUTH_GOOGLE_ID=CHANGE_ME
OAUTH_GOOGLE_SECRET=CHANGE_ME
OAUTH_FACEBOOK_ID=CHANGE_ME
OAUTH_FACEBOOK_SECRET=CHANGE_ME
# Sign in with Apple. SERVICES_ID = the Services ID (client id), not the App ID.
# Return URL: https://dashboard.checkoutly.app/connect/apple/check (query-string-free).
# The .p8 signing key is mounted read-only into the container (see docker-compose.prod.yml).
OAUTH_APPLE_SERVICES_ID=CHANGE_ME
OAUTH_APPLE_TEAM_ID=CHANGE_ME
OAUTH_APPLE_KEY_ID=CHANGE_ME
OAUTH_APPLE_KEY_PATH=/etc/checkoutly/AuthKey_4B93B6546L.p8

# --- Sentry error tracking (prod only; leave empty to disable) ---
SENTRY_DSN=
