{
	# FrankenPHP global config.
	frankenphp
	order php_server before file_server
	# Email Let's Encrypt uses for expiry notices. Set ACME_EMAIL in the env;
	# the default keeps the config valid when it is unset (e.g. local runs).
	email {$ACME_EMAIL:admin@checkoutly.app}
}

# ---------------------------------------------------------------------------
# checkoutly.app  ->  marketing site (static), EXCEPT the machine endpoints.
# ---------------------------------------------------------------------------
# The apex serves the public marketing site (a separate "marketing" nginx
# container on the shared "checkoutly-edge" network). But installed modules call
# https://checkoutly.app/api/license/status by default, and Stripe posts to
# /webhook/*, so those paths MUST keep hitting this licensing app. They are
# served here; everything else is reverse-proxied to the marketing container.
www.checkoutly.app {
	redir https://checkoutly.app{uri} permanent
}

checkoutly.app {
	encode zstd gzip

	# License API + gateway, and Stripe webhooks: served by this app.
	handle /api/* {
		root * /app/public
		php_server
	}
	handle /webhook/* {
		root * /app/public
		php_server
	}

	# Everything else: the static marketing site.
	handle {
		reverse_proxy marketing:80
	}

	log {
		output stdout
		format console
	}
}

# ---------------------------------------------------------------------------
# dashboard.checkoutly.app  ->  the licensing portal / dashboard (this app).
# ---------------------------------------------------------------------------
dashboard.checkoutly.app {
	root * /app/public
	encode zstd gzip

	php_server

	# Long-cache hashed assets.
	@static path *.css *.js *.woff2 *.svg *.png *.jpg *.webp
	header @static Cache-Control "public, max-age=31536000, immutable"

	log {
		output stdout
		format console
	}
}

# ---------------------------------------------------------------------------
# demo.checkoutly.app  ->  public demo store (separate stack). Unchanged.
# ---------------------------------------------------------------------------
# This Caddy owns 80/443 on the host, so it terminates TLS for the demo and
# reverse-proxies to the demo's PrestaShop container over "checkoutly-edge".
demo.checkoutly.app {
	encode zstd gzip

	# Keep the demo out of search results.
	header X-Robots-Tag "noindex, nofollow, noarchive"

	# Anthropic runs several crawlers (ClaudeBot, Claude-SearchBot, Claude-User),
	# and other AI bots crawl the combinatorial faceted-search (?q=) URL space,
	# which saturates PrestaShop's Apache workers and the MariaDB pool and pegs
	# the demo DB. The demo is noindex and needs no crawling, so refuse them
	# outright. Human visitors keep full faceted navigation.
	@badbots header_regexp User-Agent (?i)(Claude|GPTBot|CCBot|Bytespider|Amazonbot|meta-externalagent|ChatGPT|PerplexityBot|anthropic)
	handle @badbots {
		respond 403
	}

	# Serve our own robots.txt: keep the AI crawlers off entirely and block the
	# ?q= filter-crawl vector for every crawler.
	handle /robots.txt {
		header Content-Type text/plain
		respond `User-agent: ClaudeBot
Disallow: /

User-agent: Claude-SearchBot
Disallow: /

User-agent: *
Disallow: /*?q=
` 200
	}

	handle {
		reverse_proxy demo-prestashop:80 {
			header_up X-Forwarded-Proto https
			header_up X-Forwarded-Port 443
		}
	}

	log {
		output stdout
		format console
	}
}
